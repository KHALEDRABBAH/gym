generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id            String    @id @default(uuid())
  email         String    @unique
  name          String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Fitness Profile
  weight        Float?
  bodyFat       Float?
  targetWeight  Float?
  targetBodyFat Float?
  level         Int       @default(1)
  xp            Int       @default(0)
  streak        Int       @default(0)
  
  // Relations
  workouts      WorkoutLog[]
  nutrition     NutritionLog[]
  habits        HabitLog[]
  // Lifestyle & Productivity
  dailyTasks    DailyTask[]
  prayers       PrayerLog[]
  reviews       ReviewLog[]
  sleepLogs     SleepLog[]
}

model WorkoutLog {
  id          String    @id @default(uuid())
  userId      String
  date        String    // Format: YYYY-MM-DD for easy lookup
  workoutType String    // e.g., "Push", "Pull", "Legs"
  duration    Int?      // in minutes
  calories    Int?      
  
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  exercises   ExerciseSet[]

  @@unique([userId, date])
}

model ExerciseSet {
  id           String     @id @default(uuid())
  workoutLogId String
  exerciseId   String
  exerciseName String
  weight       Float
  reps         Int
  setIndex     Int
  rpe          Int?       // Rate of Perceived Exertion
  notes        String?
  isDropSet    Boolean    @default(false)
  superSetId   String?    // To group sets together in a superset
  
  workoutLog   WorkoutLog @relation(fields: [workoutLogId], references: [id], onDelete: Cascade)
}

model NutritionLog {
  id          String   @id @default(uuid())
  userId      String
  date        String
  calories    Int      @default(0)
  protein     Float    @default(0)
  carbs       Float    @default(0)
  fat         Float    @default(0)
  waterLiters Float    @default(0)

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([userId, date])
}

model HabitLog {
  id          String   @id @default(uuid())
  userId      String
  date        String
  habitId     String
  habitName   String
  completed   Boolean  @default(false)
  details     String?

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([userId, date, habitId])
}

model DailyTask {
  id          String   @id @default(uuid())
  userId      String
  date        String
  title       String
  completed   Boolean  @default(false)
  category    String   @default("General")
  duration    Int?     // Duration in minutes
  timeSpent   Int?     @default(0) // Time spent in seconds

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PrayerLog {
  id          String   @id @default(uuid())
  userId      String
  date        String
  fajr        Boolean  @default(false)
  dhuhr       Boolean  @default(false)
  asr         Boolean  @default(false)
  maghrib     Boolean  @default(false)
  isha        Boolean  @default(false)
  taraweeh    Boolean  @default(false)

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([userId, date])
}

model ReviewLog {
  id           String   @id @default(uuid())
  userId       String
  date         String
  type         String   // "DAILY" or "WEEKLY"
  wins         String?
  improvements String?
  notes        String?

  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([userId, date, type])
}

model SleepLog {
  id          String   @id @default(uuid())
  userId      String
  date        String
  hours       Float    @default(0)
  quality     Int      @default(3) // 1-5 scale
  notes       String?

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([userId, date])
}
